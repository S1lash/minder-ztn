{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minder.host/schemas/ztn-manifest/v2.json",
  "title": "ZTN engine batch manifest — v2.x",
  "description": "Universal output contract emitted by every ZTN engine skill that produces persistent state changes (/ztn:process, /ztn:maintain, /ztn:lint, /ztn:agent-lens). Single shape, distinguished by the top-level `processor` field. SemVer per ARCHITECTURE.md §8.12.2: MAJOR breaks consumers, MINOR additive (new optional fields, sections, entity types). Forward-compat slot `section_extras: jsonb` lives both top-level and per-section. Audience-tag whitelist enforcement happens at the ZTN registry layer (lint scan A.7 against AUDIENCES.md, owner-extensible per tenant) — this schema enforces type only. Concept-name format conformance is producer-side guarantee (ZTN normalisers in `_system/scripts/_common.py`); this schema does not re-validate the regex. Privacy trio (`origin`, `audience_tags`, `is_sensitive`) is required-slot on every Tier 0/1/2 entity emission with conservative-safe defaults applied at emission time.",

  "type": "object",
  "required": ["batch_id", "timestamp", "format_version", "processor"],
  "properties": {
    "batch_id":       { "$ref": "#/$defs/batch_id" },
    "timestamp":      { "$ref": "#/$defs/iso8601_utc" },
    "format_version": { "$ref": "#/$defs/format_version" },
    "processor":      { "$ref": "#/$defs/processor" },

    "sources_processed": {
      "type": "array",
      "description": "Sources consumed in this batch (typically transcripts under _sources/processed/).",
      "items":       { "$ref": "#/$defs/source_entry" }
    },
    "records":          { "$ref": "#/$defs/records_section" },
    "knowledge_notes":  { "$ref": "#/$defs/knowledge_notes_section" },
    "hubs":             { "$ref": "#/$defs/hubs_section" },
    "concepts":         { "$ref": "#/$defs/concepts_section" },
    "constitution":     { "$ref": "#/$defs/constitution_section" },
    "tier1_objects":    { "$ref": "#/$defs/tier1_objects_section" },
    "tier2_objects":    { "$ref": "#/$defs/tier2_objects_section" },

    "sensitive_entities": {
      "type": "array",
      "description": "Per-batch summary of every entity emitted with is_sensitive=true. Populated at /ztn:process emission time so downstream consumers can apply extra-friction policy without re-scanning.",
      "items": { "$ref": "#/$defs/sensitive_entity_entry" }
    },

    "threads_opened": {
      "type": "array",
      "description": "Strategic open-thread surfaced this batch (currently /ztn:maintain only). Tier 1 thread type is deferred — schema slot only.",
      "items": { "type": "object" }
    },
    "threads_resolved": {
      "type": "array",
      "description": "Threads resolved this batch (deferred Tier 1 type — slot only).",
      "items": { "type": "object" }
    },

    "stats":          { "$ref": "#/$defs/stats" },
    "section_extras": { "$ref": "#/$defs/section_extras" }
  },

  "allOf": [
    {
      "if":   { "properties": { "processor": { "const": "ztn:process" } } },
      "then": {
        "required": [
          "sources_processed", "records", "knowledge_notes",
          "concepts", "stats"
        ]
      }
    },
    {
      "if":   { "properties": { "processor": { "const": "ztn:maintain" } } },
      "then": { "required": ["stats"] }
    },
    {
      "if":   { "properties": { "processor": { "const": "ztn:lint" } } },
      "then": { "required": ["stats"] }
    },
    {
      "if":   { "properties": { "processor": { "const": "ztn:agent-lens" } } },
      "then": { "required": ["stats"] }
    }
  ],

  "$defs": {
    "batch_id": {
      "type": "string",
      "description": "UTC timestamp prefix `YYYYMMDD-HHMMSS`. Sortable as string, monotonically non-decreasing per skill, stable from concurrency-lock acquisition through manifest write. Filename of the manifest file is `{batch_id}-{skill}.json` (chronological consumer ordering by filename prefix per ARCHITECTURE.md §8.11.2).",
      "pattern": "^[0-9]{8}-[0-9]{6}(-[0-9]+)?$"
    },
    "iso8601_utc": {
      "type": "string",
      "description": "ISO 8601 UTC with trailing `Z`. Run-start timestamp (`timestamp`) or per-event timestamp.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "format_version": {
      "type": "string",
      "description": "Semantic version `MAJOR.MINOR`. MAJOR breaks consumers; MINOR additive. Worker `v2.X` accepts manifest `v2.Y` for any Y; rejects `v3.*` (ARCHITECTURE.md §8.12.2).",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "processor": {
      "type": "string",
      "description": "Which ZTN engine skill emitted this manifest (universal contract per ARCHITECTURE.md §8.11.1).",
      "enum": ["ztn:process", "ztn:maintain", "ztn:lint", "ztn:agent-lens"]
    },

    "section_extras": {
      "description": "Forward-compat slot for fields not yet promoted to schema. Top-level and per-section. Worker logs unknown contents but does not fail (ARCHITECTURE.md §8.12.2).",
      "type": "object",
      "additionalProperties": true
    },

    "concept_name": {
      "type": "string",
      "description": "Snake_case ASCII concept identifier per `_system/registries/CONCEPT_NAMING.md`. Producer-side guarantee — ZTN normalisers in `_common.py` enforce the format BEFORE manifest emission. Schema accepts any string here so consumer round-trips of legitimate names with internal underscores stay valid; format violations would only appear if producer-side guarantee is bypassed (caught by lint Scan A.7 defence-in-depth).",
      "minLength": 1,
      "maxLength": 64
    },
    "concept_name_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/concept_name" }
    },
    "concept_type_enum": {
      "type": "string",
      "description": "Concept type. ZTN-emitted manifests deliberately exclude `person` and `project` from `concepts.upserts[]` — those have first-class channels (`tier1_objects.people`, `tier1_objects.projects`). The full CONCEPT_NAMING enum is wider (18 values incl. person/project) to cover downstream graph completeness; this schema's emission enum is the 16-value ZTN subset.",
      "enum": [
        "theme", "tool", "decision", "idea", "event", "organization",
        "skill", "location", "emotion", "goal", "value", "preference",
        "constraint", "algorithm", "fact", "other"
      ]
    },

    "origin": {
      "type": "string",
      "description": "Provenance — where this entity was captured. ARCHITECTURE.md §8.10.2. The `personal | work | external` core values plus the bootstrap-* / sync-* prefixes for synthetic origins (bootstrap-raw-scan, bootstrap-profile, sync-jira, etc.). Default `personal` (fail-closed).",
      "anyOf": [
        { "enum": ["personal", "work", "external"] },
        { "pattern": "^bootstrap-[a-z0-9-]+$" },
        { "pattern": "^sync-[a-z0-9-]+$" }
      ]
    },
    "audience_tags": {
      "type": "array",
      "description": "Whitelist enforcement lives in `/ztn:lint` Scan A.7 reading `_system/registries/AUDIENCES.md` (canonical 5 + tenant-extensible Extensions table). Schema cannot enumerate dynamic per-tenant extensions; type-only check here. Default `[]` (owner-only — ARCHITECTURE.md §8.10.2).",
      "items": { "type": "string" }
    },
    "is_sensitive": {
      "type": "boolean",
      "description": "Extra-friction modifier on share. Orthogonal to `audience_tags` — does NOT narrow the audience. Default `false` (ARCHITECTURE.md §8.10.2)."
    },
    "privacy_trio_required": {
      "type": "object",
      "description": "Privacy trio is a required slot on every Tier 0/1/2 entity emission. Defaults applied at emission, not at validation — schema enforces presence + type. Carry by reference: every entity entry sets all three.",
      "required": ["origin", "audience_tags", "is_sensitive"],
      "properties": {
        "origin":        { "$ref": "#/$defs/origin" },
        "audience_tags": { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":  { "$ref": "#/$defs/is_sensitive" }
      }
    },

    "checksum_sha256": {
      "type": "string",
      "description": "Hex-encoded SHA-256 over the file's bytes at emission time. Drives consumer's idempotency (skip re-ingest on unchanged checksum) and graph-edge reconciliation (delta-aware diff on change — ARCHITECTURE.md §8.11.6 invariant 1).",
      "pattern": "^[0-9a-f]{64}$"
    },

    "source_entry": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path":            { "type": "string" },
        "source_type":     { "type": "string", "description": "Whitelist in `_system/registries/SOURCES.md` (e.g. plaud, claude-session, manual)." },
        "source_id":       { "type": "string" },
        "checksum_sha256": { "$ref": "#/$defs/checksum_sha256" },
        "size_bytes":      { "type": "integer", "minimum": 0 },
        "section_extras":  { "$ref": "#/$defs/section_extras" }
      }
    },

    "domains_array": {
      "type": "array",
      "description": "Canonical 13 + tenant Extensions per `_system/registries/DOMAINS.md`. Whitelist enforcement at lint, not in schema (per-tenant extensions can't be schema-enumerated).",
      "items": { "type": "string" }
    },

    "record_entry": {
      "type": "object",
      "required": ["path", "origin", "audience_tags", "is_sensitive"],
      "properties": {
        "path":            { "type": "string" },
        "id":              { "type": "string" },
        "title":           { "type": "string" },
        "checksum_sha256": { "$ref": "#/$defs/checksum_sha256" },
        "people":          { "type": "array", "items": { "type": "string" }, "description": "Resolved person IDs (kebab-case slugs from PEOPLE.md). Alias `people_ids` accepted for downstream compatibility." },
        "people_ids":      { "type": "array", "items": { "type": "string" } },
        "projects":        { "type": "array", "items": { "type": "string" } },
        "domains":         { "$ref": "#/$defs/domains_array" },
        "concept_hints":   { "$ref": "#/$defs/concept_name_list" },
        "primary_type":    { "type": "string" },
        "types":           { "type": "array", "items": { "type": "string" } },
        "origin":          { "$ref": "#/$defs/origin" },
        "audience_tags":   { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":    { "$ref": "#/$defs/is_sensitive" },
        "section_extras":  { "$ref": "#/$defs/section_extras" }
      }
    },
    "records_section": {
      "type": "object",
      "properties": {
        "created":        { "type": "array", "items": { "$ref": "#/$defs/record_entry" } },
        "updated":        { "type": "array", "items": { "$ref": "#/$defs/record_entry" } },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "knowledge_note_entry": {
      "type": "object",
      "required": ["path", "origin", "audience_tags", "is_sensitive"],
      "properties": {
        "path":            { "type": "string" },
        "id":              { "type": "string" },
        "title":           { "type": "string" },
        "checksum_sha256": { "$ref": "#/$defs/checksum_sha256" },
        "types":           { "type": "array", "items": { "type": "string" } },
        "primary_type":    { "type": "string" },
        "domains":         { "$ref": "#/$defs/domains_array" },
        "concept_hints":   { "$ref": "#/$defs/concept_name_list" },
        "people":          { "type": "array", "items": { "type": "string" } },
        "people_ids":      { "type": "array", "items": { "type": "string" } },
        "projects":        { "type": "array", "items": { "type": "string" } },
        "supersedes":      { "type": "array", "items": { "type": "string" }, "description": "Knowledge-note IDs this note supersedes. Edge `SUPERSEDES` in graph (ARCHITECTURE.md §8.11.4)." },
        "superseded_by":   { "type": ["string", "null"] },
        "merged_from":     { "type": "array", "items": { "type": "string" } },
        "status":          { "type": "string", "description": "Lifecycle: active | archived | superseded | dormant. Append-only — no hard-deletes (ARCHITECTURE.md §8.11.6 invariant 2)." },
        "origin":          { "$ref": "#/$defs/origin" },
        "audience_tags":   { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":    { "$ref": "#/$defs/is_sensitive" },
        "section_extras":  { "$ref": "#/$defs/section_extras" }
      }
    },
    "knowledge_notes_section": {
      "type": "object",
      "properties": {
        "created":        { "type": "array", "items": { "$ref": "#/$defs/knowledge_note_entry" } },
        "updated":        { "type": "array", "items": { "$ref": "#/$defs/knowledge_note_entry" } },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "hub_entry": {
      "type": "object",
      "required": ["path", "origin", "audience_tags", "is_sensitive"],
      "properties": {
        "id":                          { "type": "string" },
        "path":                        { "type": "string" },
        "checksum_sha256":             { "$ref": "#/$defs/checksum_sha256" },
        "member_concepts":             { "$ref": "#/$defs/concept_name_list" },
        "member_notes":                { "type": "array", "items": { "type": "string" } },
        "domains":                     { "$ref": "#/$defs/domains_array" },
        "hub_kind":                    { "enum": ["project", "trajectory", "domain"], "description": "ARCH-B hub kind. Defaults `project` when absent (backward-compat)." },
        "chronological_map_mode":      { "enum": ["derived", "curated"] },
        "excluded_from_map_count":     { "type": "integer", "minimum": 0 },
        "auto_member_count":           { "type": "integer", "minimum": 0 },
        "origin":                      { "$ref": "#/$defs/origin" },
        "audience_tags":               { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":                { "$ref": "#/$defs/is_sensitive" },
        "section_extras":              { "$ref": "#/$defs/section_extras" }
      }
    },
    "hubs_section": {
      "type": "object",
      "properties": {
        "created":        { "type": "array", "items": { "$ref": "#/$defs/hub_entry" } },
        "updated":        { "type": "array", "items": { "$ref": "#/$defs/hub_entry" } },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "concept_upsert_entry": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name":              { "$ref": "#/$defs/concept_name" },
        "type":              { "$ref": "#/$defs/concept_type_enum" },
        "subtype":           { "anyOf": [{ "$ref": "#/$defs/concept_name" }, { "type": "null" }] },
        "related_concepts":  { "$ref": "#/$defs/concept_name_list" },
        "previous_slugs":    { "$ref": "#/$defs/concept_name_list" },
        "status":            { "enum": ["active", "deprecated"], "description": "Default `active`. /ztn:lint emits `deprecated` after multi-step CLARIFICATION review (ARCHITECTURE.md §8.11.4)." },
        "section_extras":    { "$ref": "#/$defs/section_extras" }
      }
    },
    "concepts_section": {
      "type": "object",
      "properties": {
        "upserts":        { "type": "array", "items": { "$ref": "#/$defs/concept_upsert_entry" } },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "principle_relation": {
      "type": "object",
      "required": ["slug", "type"],
      "properties": {
        "slug": { "type": "string" },
        "type": { "type": "string", "description": "REFINES | NESTED_UNDER | SUPERSEDES | CONTRADICTS — see ARCHITECTURE.md §6.4.0 graph relationships." }
      }
    },
    "principle_upsert_entry": {
      "type": "object",
      "description": "Tier 0 constitution principle (axiom / principle / rule). Full schema per SD012 + ARCHITECTURE.md §6.4.0.",
      "required": ["slug", "tier", "origin", "audience_tags", "is_sensitive"],
      "properties": {
        "id":                       { "type": "string", "description": "Stable UUID across syncs (consumer-assigned if absent)." },
        "slug":                     { "type": "string", "description": "e.g. axiom-ethics-001" },
        "previous_slugs":           { "type": "array", "items": { "type": "string" } },
        "title":                    { "type": "string" },
        "body_markdown":            { "type": "string" },
        "tier":                     { "enum": ["axiom", "principle", "rule"] },
        "domains":                  { "$ref": "#/$defs/domains_array" },
        "scopes":                   { "type": "array", "items": { "type": "string" } },
        "origin":                   { "$ref": "#/$defs/origin" },
        "capture_metadata":         { "type": "object", "description": "Free-form jsonb: captured_in_session, evidence_text, surrounding context.", "additionalProperties": true },
        "source_path":              { "type": "string" },
        "checksum_sha256":          { "$ref": "#/$defs/checksum_sha256" },
        "tags":                     { "type": "array", "items": { "type": "string" }, "description": "Owner-defined custom taxonomy beyond domains/scopes." },
        "status":                   { "enum": ["active", "archived", "superseded", "dormant"] },
        "audience_tags":            { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":             { "$ref": "#/$defs/is_sensitive" },
        "applies_in_concepts":      { "$ref": "#/$defs/concept_name_list" },
        "relates_to_principles":    { "type": "array", "items": { "$ref": "#/$defs/principle_relation" } },
        "revision":                 { "type": "integer", "minimum": 1 },
        "extras":                   { "type": "object", "additionalProperties": true, "description": "Forward-compat jsonb (ARCHITECTURE.md §6.4.0)." },
        "section_extras":           { "$ref": "#/$defs/section_extras" }
      }
    },
    "principle_archived_entry": {
      "type": "object",
      "required": ["slug"],
      "properties": {
        "slug":         { "type": "string" },
        "reason":       { "type": "string" },
        "archived_on":  { "type": "string" }
      }
    },
    "principle_superseded_entry": {
      "type": "object",
      "required": ["slug", "by_slug"],
      "properties": {
        "slug":     { "type": "string" },
        "by_slug":  { "type": "string" },
        "on":       { "type": "string" }
      }
    },
    "constitution_section": {
      "type": "object",
      "properties": {
        "principles": {
          "type": "object",
          "properties": {
            "upserts":        { "type": "array", "items": { "$ref": "#/$defs/principle_upsert_entry" } },
            "archived":       { "type": "array", "items": { "$ref": "#/$defs/principle_archived_entry" } },
            "superseded":     { "type": "array", "items": { "$ref": "#/$defs/principle_superseded_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "constitution_core_view": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["path"],
              "properties": {
                "path":            { "type": "string" },
                "checksum_sha256": { "$ref": "#/$defs/checksum_sha256" },
                "principle_slugs": { "type": "array", "items": { "type": "string" } },
                "section_extras":  { "$ref": "#/$defs/section_extras" }
              }
            }
          ]
        },
        "soul": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["path"],
              "properties": {
                "path":            { "type": "string" },
                "checksum_sha256": { "$ref": "#/$defs/checksum_sha256" },
                "fields": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "working_style, goals_work, goals_personal, current_focus_work, current_focus_personal — see ARCHITECTURE.md §6.4.0 SOUL companion."
                },
                "section_extras":  { "$ref": "#/$defs/section_extras" }
              }
            }
          ]
        },
        "candidates_appended": { "type": "integer", "minimum": 0, "description": "Count of principle candidates appended to `_system/state/principle-candidates.jsonl` this batch (slot only — full candidate buffer never lands in manifest)." },
        "section_extras":      { "$ref": "#/$defs/section_extras" }
      }
    },

    "tier1_entity_base": {
      "type": "object",
      "required": ["origin", "audience_tags", "is_sensitive"],
      "properties": {
        "origin":         { "$ref": "#/$defs/origin" },
        "audience_tags":  { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":   { "$ref": "#/$defs/is_sensitive" },
        "status":         { "type": "string", "description": "Append-only lifecycle (active | archived | superseded | dormant). Type-specific lifecycles (e.g. tasks add OPEN/IN_PROGRESS/DONE/CANCELLED in `task_status`) are separate fields." },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "tier1_task_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id", "title"],
          "properties": {
            "id":                  { "type": "string" },
            "title":               { "type": "string" },
            "ownership":           { "type": "string", "description": "MINE | DELEGATED | WAITING — see Task Manager spec." },
            "deadline":            { "type": ["string", "null"], "description": "YYYY-MM-DD or null." },
            "task_status":         { "type": "string", "description": "OPEN | IN_PROGRESS | DONE | CANCELLED" },
            "concept_ids":         { "$ref": "#/$defs/concept_name_list" },
            "people_ids":          { "type": "array", "items": { "type": "string" } },
            "source_record_path":  { "type": "string" }
          }
        }
      ]
    },
    "tier1_idea_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id":                  { "type": "string" },
            "title":               { "type": "string" },
            "concept_ids":         { "$ref": "#/$defs/concept_name_list" },
            "people_ids":          { "type": "array", "items": { "type": "string" } },
            "source_record_path":  { "type": "string" }
          }
        }
      ]
    },
    "tier1_event_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id":                  { "type": "string" },
            "title":               { "type": "string" },
            "from_date":           { "type": "string" },
            "to_date":             { "type": ["string", "null"] },
            "participants":        { "type": "array", "items": { "type": "string" } },
            "concept_ids":         { "$ref": "#/$defs/concept_name_list" },
            "source_record_path":  { "type": "string" }
          }
        }
      ]
    },
    "tier1_decision_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id":                            { "type": "string" },
            "title":                         { "type": "string" },
            "made_on":                       { "type": "string" },
            "alternatives":                  { "type": "array", "items": { "type": "string" } },
            "rationale":                     { "type": "string" },
            "supersedes_ids":                { "type": "array", "items": { "type": "string" } },
            "evidence_concept_ids":          { "$ref": "#/$defs/concept_name_list" },
            "evidence_record_paths":         { "type": "array", "items": { "type": "string" } },
            "source_knowledge_note_path":    { "type": "string" }
          }
        }
      ]
    },
    "tier1_person_entry": {
      "type": "object",
      "description": "People upserts. Privacy trio NOT required at row level (PEOPLE.md is owner-curated registry — see batch-format.md `Owner-curated registries`); accepted opportunistically. `tier_suggested` is /ztn:maintain's soft suggestion (separate from `tier`) — applied only after owner approval via `/ztn:resolve-clarifications` (ARCHITECTURE.md §8.11.3).",
      "required": ["id"],
      "properties": {
        "id":                    { "type": "string" },
        "display_name":          { "type": "string" },
        "org":                   { "type": "string" },
        "tier":                  { "type": "string", "description": "Current tier as recorded in PEOPLE.md (T1 / T2 / etc.)." },
        "tier_suggested":        { "type": "string", "description": "/ztn:maintain soft suggestion. Distinct from `tier`. Owner approval via CLARIFICATION; next batch carries application." },
        "mention_count":         { "type": "integer", "minimum": 0 },
        "mention_count_delta":   { "type": "integer" },
        "origin":                { "$ref": "#/$defs/origin" },
        "audience_tags":         { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":          { "$ref": "#/$defs/is_sensitive" },
        "section_extras":        { "$ref": "#/$defs/section_extras" }
      }
    },
    "tier1_project_entry": {
      "type": "object",
      "description": "Project upserts (PROJECTS.md is owner-curated; trio optional).",
      "required": ["id"],
      "properties": {
        "id":             { "type": "string" },
        "display_name":   { "type": "string" },
        "scope":          { "type": "string", "description": "work | personal | side | mixed" },
        "status":         { "type": "string" },
        "origin":         { "$ref": "#/$defs/origin" },
        "audience_tags":  { "$ref": "#/$defs/audience_tags" },
        "is_sensitive":   { "$ref": "#/$defs/is_sensitive" },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },
    "tier1_content_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id":              { "type": "string" },
            "title":           { "type": "string" },
            "content_type":    { "type": "string" },
            "content_angle":   { "type": "string" },
            "draft_path":      { "type": "string" },
            "concept_ids":     { "$ref": "#/$defs/concept_name_list" }
          }
        }
      ]
    },

    "created_updated_section": {
      "description": "Generic shape for Tier 1 typed sections that distinguish creates from updates (tasks, ideas, events, decisions, content).",
      "type": "object",
      "properties": {
        "created":        { "type": "array" },
        "updated":        { "type": "array" },
        "merged":         { "type": "array" },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },
    "upserts_section": {
      "description": "Generic shape for sections that emit upserts only (people, projects, concepts).",
      "type": "object",
      "properties": {
        "upserts":        { "type": "array" },
        "section_extras": { "$ref": "#/$defs/section_extras" }
      }
    },

    "tier1_objects_section": {
      "type": "object",
      "properties": {
        "tasks": {
          "type": "object",
          "properties": {
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_task_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_task_entry" } },
            "merged":         { "type": "array", "items": { "type": "object" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "ideas": {
          "type": "object",
          "properties": {
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_idea_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_idea_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "events": {
          "type": "object",
          "properties": {
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_event_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_event_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "decisions": {
          "type": "object",
          "properties": {
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_decision_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_decision_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "people": {
          "type": "object",
          "properties": {
            "upserts":        { "type": "array", "items": { "$ref": "#/$defs/tier1_person_entry" } },
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_person_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_person_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "projects": {
          "type": "object",
          "properties": {
            "upserts":        { "type": "array", "items": { "$ref": "#/$defs/tier1_project_entry" } },
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_project_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_project_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "content": {
          "type": "object",
          "properties": {
            "created":        { "type": "array", "items": { "$ref": "#/$defs/tier1_content_entry" } },
            "updated":        { "type": "array", "items": { "$ref": "#/$defs/tier1_content_entry" } },
            "section_extras": { "$ref": "#/$defs/section_extras" }
          }
        },
        "section_extras":     { "$ref": "#/$defs/section_extras" }
      }
    },

    "tier2_typed_object_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "required": ["id", "type", "name"],
          "properties": {
            "id":              { "type": "string" },
            "type":            { "type": "string", "description": "Registered Tier 2 type name (inventory, wardrobe, content_candidates, lens-observation, ...)." },
            "external_id":     { "type": ["string", "null"] },
            "name":            { "type": "string" },
            "normalized_name": { "type": "string" },
            "payload":         { "type": "object", "additionalProperties": true, "description": "Free-form per registered schema — see `_system/registries/...` per type." }
          }
        }
      ]
    },

    "tier2_lens_observation_entry": {
      "allOf": [
        { "$ref": "#/$defs/tier1_entity_base" },
        {
          "type": "object",
          "description": "Tier 2 lens-observation per ARCHITECTURE.md §8.11.5 + §6.4.2. `identity_fields: [lens_name, observed_on]` — schema documents but does not enforce uniqueness (downstream consumer enforces).",
          "required": ["lens_name", "observed_on", "is_hypothesis"],
          "properties": {
            "id":                       { "type": "string" },
            "lens_name":                { "type": "string", "description": "energy-pattern | global-navigator | decision-review | stalled-thread | stated-vs-lived | cross-domain-bridge | ..." },
            "observed_on":              { "type": "string", "description": "YYYY-MM-DD." },
            "observation_period":       { "type": "string", "description": "Free-form: \"last 4 weeks\", \"since 2026-04-01\"." },
            "body_markdown":            { "type": "string" },
            "is_hypothesis":            { "type": "boolean", "const": true, "description": "Always true — lens output is hypothesis, not fact (ARCHITECTURE.md §8.11.6 invariant 3)." },
            "generated_by_lens_run":    { "type": "string", "description": "Reference to entry in `_system/state/agent-lens-runs.jsonl`." },
            "related_concepts":         { "$ref": "#/$defs/concept_name_list" },
            "related_entity_refs":      { "type": "object", "additionalProperties": true, "description": "Free-form jsonb — references to decisions/threads/people analysed." },
            "prompt_version":           { "type": "string", "description": "Which prompt generated this — tracking model evolution." },
            "path":                     { "type": "string", "description": "Source markdown at `_system/agent-lens/{lens-name}/{date}.md`." },
            "checksum_sha256":          { "$ref": "#/$defs/checksum_sha256" }
          }
        }
      ]
    },

    "tier2_objects_section": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "inventory":         { "type": "object", "properties": { "upserts": { "type": "array", "items": { "$ref": "#/$defs/tier2_typed_object_entry" } } } },
            "wardrobe":          { "type": "object", "properties": { "upserts": { "type": "array", "items": { "$ref": "#/$defs/tier2_typed_object_entry" } } } },
            "content_candidates":{ "type": "object", "properties": { "upserts": { "type": "array", "items": { "$ref": "#/$defs/tier2_typed_object_entry" } } } },
            "lens_observation":  { "type": "object", "properties": { "upserts": { "type": "array", "items": { "$ref": "#/$defs/tier2_lens_observation_entry" } } } },
            "section_extras":    { "$ref": "#/$defs/section_extras" }
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "upserts":        { "type": "array", "items": { "$ref": "#/$defs/tier2_typed_object_entry" } },
              "section_extras": { "$ref": "#/$defs/section_extras" }
            },
            "description": "Open-ended additional Tier 2 type sections (reading_list, expense_items, future-registered types). Each follows the generic `{upserts: [...]}` shape."
          }
        },
        {
          "type": "array",
          "maxItems": 0,
          "description": "Tolerated empty-shorthand `[]` from early /process emissions when no Tier 2 entities existed. Forward-compat: emitters SHOULD write `{}` instead. Producer-side normaliser in emit_batch_manifest.py coerces `[]` → `{}`."
        }
      ]
    },

    "sensitive_entity_entry": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "path":          { "type": "string" },
        "id":            { "type": "string" },
        "kind":          { "type": "string", "description": "record | note | hub | task | event | idea | decision | person | project | content | principle | lens-observation | typed-object" },
        "audience_tags": { "$ref": "#/$defs/audience_tags" }
      }
    },

    "stats": {
      "type": "object",
      "description": "Per-skill counters. Per-skill semantics differ — see ARCHITECTURE.md §8.11. Schema accepts unknown keys via additionalProperties so new counters land without a major bump.",
      "additionalProperties": true
    }
  }
}
