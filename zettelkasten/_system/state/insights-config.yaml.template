# Per-clone overrides for the smart-resolve engine driven by
# `/ztn:resolve-clarifications`. The defaults below match a fresh clone;
# uncomment and edit any line to override. Engine reads this file at
# the start of every resolve session — no restart needed.
#
# Path: `_system/state/insights-config.yaml` (this template ships under
# `.template` and is copied into place at first resolve run when the
# live file is missing).
#
# This file is OWNER DATA. After installation it stops syncing from
# upstream — your edits survive `/ztn:update`.

# Per-class auto-apply overrides. Keys take the form
# `{lens-id}__{action-type}__{confidence}` with `*` accepted as a
# wildcard for the confidence segment. Values: `auto` (force apply
# regardless of pattern history), `never_auto` (always queue), or
# omit the entry to use the engine default (LLM-judged from history).
classes:
  # cross-domain-bridge__wikilink_add__high: auto
  # knowledge-emergence__hub_stub_create__*: never_auto

  # cognitive-model proposes principles about HOW you think (mined from your
  # reflections). It may auto-append a candidate to the review buffer ONLY when
  # highly confident (low friction on the obvious cases); medium / low always
  # wait for your click — nothing about your mind is recorded uncertainly
  # while you sleep. Promotion to the constitution stays gated by /ztn:lint F.5
  # regardless of these. Loosen to `*: auto` if you want all of it autonomous;
  # tighten `__high` to `never_auto` if you want to click every single one.
  cognitive-model__principle_candidate_add__high: auto
  cognitive-model__principle_candidate_add__medium: never_auto
  cognitive-model__principle_candidate_add__low: never_auto

# Reasoning posture. Hint to the resolver LLM, not a hard threshold.
reasoning:
  # `conservative` — require strong precedent + clean constitution
  # `balanced`     — default; weighted reasoning over precedent + context
  # `aggressive`   — willing to auto on weaker precedent (not recommended
  #                  for early adoption)
  posture: balanced

  # Default when the LLM is uncertain whether to auto-apply or queue.
  # Owner-friendly default is `queue` — auto-apply is earned, not assumed.
  uncertainty_default: queue

# Coalescing rules — when multiple lenses propose substantively the same
# action, the resolver merges them into a single clarification with options.
coalescing:
  enabled: true
  # LLM-judged similarity hint. The resolver does NOT use this as a
  # deterministic threshold — it is signal to the curator prompt.
  similarity_threshold: 0.6

# Biometric pipeline overrides.
biometric:
  # Anti-DDoS — max biometric-origin action hints surfaced to the
  # resolve queue per ISO week. When exceeded, top-by-effect-size
  # win; rest defer to next week.
  biometric_max_hints_per_week: 3

  # When true, /ztn:maintain Tier II calibration check runs and may
  # surface `biometric-threshold-drift` CLARIFICATIONs.
  biometric_calibration_check_enabled: true

  # Clarification classes the calibration check is allowed to emit.
  # Only `threshold_tune_proposal` is whitelisted by default.
  biometric_calibration_proposal_classes:
    - threshold_tune_proposal
