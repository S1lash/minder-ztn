.DS_Store
.idea/
.idea/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# Local Claude Code state
.claude/settings.local.json
.claude/CLAUDE.local.md
zettelkasten/.claude/settings.local.json

# Rendered integration files (generated by integrations/claude-code/install.sh)
integrations/claude-code/built/

# Scheduler tick scratch state — bash helpers in scripts/scheduler/ pass
# values (e.g. START_BRANCH for cleanup-sandbox.sh) between scripts here.
.scheduler-state/

# Advisory flock files for telemetry / append-only buffers
zettelkasten/_system/state/.*.lock

# Staged outward acts awaiting the owner's --approve-acts. Transient, per-CLONE working
# state (captured on THIS clone's tick, approved on THIS clone) — kept LOCAL so it never
# splits brain across clones sharing one external board. Re-derived every reconcile.
zettelkasten/_system/roles/*/pending_acts.json

# ActivityWatch raw event dumps — kept LOCAL as the incident escape hatch,
# never committed. ~180 KB/day gzipped (≈ hundreds of MB/year) AND the most
# sensitive data in the base (months of verbatim window titles + client URLs).
# The per-day `.md` preserves the signal (## Detailed aggregates + top titles);
# raw is only needed for one-off event-level investigation on the collecting
# Mac. (Deliberately unlike garmin/oura raw, which is tiny low-sensitivity JSON.)
zettelkasten/_sources/inbox/activitywatch/raw/
zettelkasten/_sources/processed/activitywatch/raw/

# Temporary planning / SDD docs (deleted at end of implementation cycle)
_planning/

# Obsidian — per-device state, never in git. The seeded `.obsidian/`
# config is owner-data after seed; only volatile per-device files are
# ignored here. To put the whole `.obsidian/` under version control,
# remove these lines.
zettelkasten/.obsidian/workspace.json
zettelkasten/.obsidian/workspace-mobile.json
zettelkasten/.obsidian/workspaces.json
zettelkasten/.obsidian/cache
zettelkasten/.obsidian/.trash/
zettelkasten/.obsidian.backup-*/
zettelkasten/.obsidian/graph.json.bak-*
# graph.json mixes owner config (color groups, filters, forces) with
# volatile view state (scale, close) that Obsidian rewrites on every
# pan/zoom. Seed lives in integrations/obsidian/vault-config/graph.json;
# recover/sync customisations via `integrations/obsidian/seed.sh --reset-graph`.
zettelkasten/.obsidian/graph.json
# Community plugin source code is installed locally per device — don't
# commit. Plugin enablement (`community-plugins.json`) and per-plugin
# config (`plugins/<id>/data.json`) ARE committed so settings sync.
zettelkasten/.obsidian/plugins/*/main.js
zettelkasten/.obsidian/plugins/*/manifest.json
zettelkasten/.obsidian/plugins/*/styles.css
